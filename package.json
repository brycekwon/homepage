{
    "name": "homepage",
    "version": "1.0.1",
    "description": "Simple developer portfolio that aggregates projects, posts, and stats.",
    "type": "module",
    "scripts": {
        "gen": "hugo build --gc --cleanDestinationDir --templateMetrics --templateMetricsHints",
        "dev": "hugo server --gc --cleanDestinationDir --buildDrafts --disableFastRender --watch",
        "clean": "rm -rf public/ resources/ .hugo_build.lock hugo_stats.json",
        "lint": "npm run lint:js && npm run lint:md",
        "lint:js": "npx eslint -c ./eslint.config.js assets/js/*.js --no-warn-ignored",
        "lint:md": "npx markdownlint-cli -c ./markdownlint.config.json content"
    },
    "dependencies": {
        "@fullhuman/postcss-purgecss": "^7.0.2",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.5.1",
        "postcss-cli": "^11.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "eslint": "^9.19.0",
        "globals": "^15.14.0",
        "markdownlint-cli": "^0.44.0"
    }
}
